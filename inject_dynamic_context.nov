rule InjectDynamicContext
{
    meta:
        description = "Detects dynamic context injection inside agent skills. The !command` syntax executes a shell command first, then inserts its output into the prompt sent to Claude."
        author = "Marco Pedrinazzi (@pedrinazziM)"
        version = "1.0.0"
        category = "abusing_functions/agentic_misuse"
        severity = "high"
        uuid = "1c5658b3-5722-4eb9-bc4f-8d033008380b"
        date = "2026-03-18"
        reference = "https://code.claude.com/docs/en/skills#inject-dynamic-context"

    keywords:
        $command_placeholder = /!\`.+?\`/

    condition:
        keywords.$command_placeholder
}
